<!DOCTYPE html>
<html>
    <head>
        {{ importmap() }}
        <meta charset="UTF-8">
        <title>{% block title %}Welcome!{% endblock %}</title>
        <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>⚫️</text><text y=%221.3em%22 x=%220.2em%22 font-size=%2276%22 fill=%22%23fff%22>sf</text></svg>">
        {% block stylesheets %}
        {% endblock %}

        {% block javascripts %}
            {% block importmap %}{{ importmap('app') }}{% endblock %}
        {% endblock %}
        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@4.4.1/dist/css/bootstrap.min.css" integrity="sha384-Vkoo8x4CGsO3+Hhxv8T/Q5PaXtkKtu6ug5TOeNV6gBiFeWPGFN9MuhOf23Q9Ifjh" crossorigin="anonymous">
    </head>
    <body>
        {% block body %}{% endblock %}
        <div class="modal" tabindex="-1" id="remove-entity-modal">
            <div class="modal-dialog">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title">Удаление <span id="remove-entity-header-name"></span></h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <form id="remove-entity-form" action="" method="POST">
                    <div class="modal-body">
                        <p class="alert alert-danger">Вы уверены, что хотите удалить <span id="remove-entity-text-name"></span> (Процесс является необратимым)</p>
                    </div>
                    <div class="modal-footer">
                        <input type="submit" id="remove-entity-button" class="btn btn-danger" value="Удалить"/>
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal" data-dismiss="modal">Отмена</button>
                    </div>
                    </form>
                </div>
            </div>
        </div>
        <div class="modal fade"  tabindex="-1" id="remove-entity-error-modal" role="dialog">
            <div class="modal-dialog">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title">Ошибка удаления</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <form id="remove-entity-form" action="" method="POST">
                        <div class="modal-body">
                            <p class="alert alert-danger" id="remove-entity-error-message"></p>
                        </div>
                        <div class="modal-footer">
                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal" data-dismiss="modal">Закрыть</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
        <script src="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/js/bootstrap.min.js"></script>

        <script type="text/javascript">
        function showRemoveModal(entityId, removeUrl, removeHeaderName, removeTextName){
            $('#remove-entity-header-name').html(removeHeaderName);
            $('#remove-entity-text-name').html(removeTextName);
            $('#remove-entity-form').attr('action', '/' + removeUrl + '/' + entityId);
            $('#remove-entity-modal').modal('show');
        }

        function showOnHandModal(bookId){
                $('#set-book-on-hand-form').attr('action', '/set_on_hand/' + bookId);
                $('#change-book-on-hand-modal').modal('show');
        }

        function showUnBookModal(bookId){
            $('#set-book-unbooking-form').attr('action', '/unbook/' + bookId);
            $('#change-book-unbooking-modal').modal('show');
        }

        $(document).ready(function() {
            let errMess = $('#error-message-val');

            if(errMess.length > 0 && errMess.val()){
                $('#remove-entity-error-message').html(errMess.val());
                $('#remove-entity-error-modal').modal('show');
            }
        });
    </script>
    </body>
</html>
